<div class="container my-5 py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card fintech-card border-0 p-5 shadow-sm text-center">
                <div class="bg-primary-subtle text-primary d-inline-flex p-3 rounded-circle mb-3">
                    <i class="bi bi-headset fs-2"></i>
                </div>
                <h1 class="fw-bold mb-3">Get in Touch</h1>
                <p class="text-muted mb-4">We are here to help you 24/7. Drop us a message or reach out via our support
                    channels.</p>

                <hr class="my-4 opacity-25">

                <div class="row g-4 text-start mt-2">
                    <div class="col-sm-6">
                        <div class="p-4 bg-light rounded-3 h-100 border">
                            <i class="bi bi-envelope-fill text-primary fs-3 mb-2 d-block"></i>
                            <h6 class="fw-bold">Email Support</h6>
                            <a href="mailto:support@secure-ewallet.com"
                                class="text-decoration-none small">support@securewallet.com</a>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="p-4 bg-light rounded-3 h-100 border">
                            <i class="bi bi-telephone-fill text-success fs-3 mb-2 d-block"></i>
                            <h6 class="fw-bold">Phone Support</h6>
                            <a href="tel:+18005550199" class="text-decoration-none small text-dark">+1 (800)
                                555-0199</a>
                        </div>
                    </div>
                </div>

                <form class="mt-5 text-start" action="#" method="get">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">Send us a Message</h5>
                    <div class="mb-3">
                        <label class="form-label small fw-medium">Full Name</label>
                        <input type="text" class="form-control" placeholder="John Doe">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-medium">Email Address</label>
                        <input type="email" class="form-control" placeholder="john@example.com">
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-medium">Message</label>
                        <textarea class="form-control" rows="4" placeholder="How can we help you?"></textarea>
                    </div>
                    <button type="button" class="btn gradient-btn rounded-pill px-4 w-100 py-3"
                        onclick="alert('Message Sent!')">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</div>