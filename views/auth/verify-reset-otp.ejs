<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card fintech-card p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="bg-primary-subtle text-primary d-inline-flex p-3 rounded-circle mb-3">
                        <i class="bi bi-chat-left-dots-fill fs-2"></i>
                    </div>
                    <h2 class="fw-bold fs-3">Verify OTP</h2>
                    <p class="text-muted">Enter the 6-digit OTP sent to <strong>
                            <%= email %>
                        </strong> to continue resetting your password.</p>
                </div>

                <form action="/auth/verify-reset-otp" method="POST">
                    <div class="form-floating mb-4">
                        <input type="text" class="form-control" id="otp" name="otp" placeholder="123456" maxlength="6"
                            pattern="\d{6}" required>
                        <label for="otp">6-Digit OTP</label>
                    </div>

                    <button class="btn gradient-btn w-100 py-3 rounded-pill fw-semibold shadow-sm mb-3"
                        type="submit">Verify OTP</button>

                    <div class="text-center mt-3">
                        <a href="/auth/forgot-password"
                            class="text-primary text-decoration-none fw-semibold small">Resend OTP</a>
                    </div>
                </form>
            </div>

            <div class="text-center mt-4">
                <small class="text-muted"><i class="bi bi-lock-fill"></i> Your connection is secure and
                    encrypted.</small>
            </div>

            <div class="text-center mt-3">
                <a href="/auth/login" class="text-muted text-decoration-none"><i class="bi bi-arrow-left"></i> Back
                    to Login</a>
            </div>
        </div>
    </div>
</div>