<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card fintech-card p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="bg-primary-subtle text-primary d-inline-flex p-3 rounded-circle mb-3">
                        <i class="bi bi-box-arrow-in-right fs-2"></i>
                    </div>
                    <h2 class="fw-bold fs-3">Welcome Back</h2>
                    <p class="text-muted">Enter your credentials to access your wallet</p>
                </div>



                <form action="/auth/login" method="POST">
                    <div class="form-floating mb-3">
                        <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com"
                            value="<%= typeof attemptEmail !== 'undefined' ? attemptEmail : '' %>" required>
                        <label for="email">Email address</label>
                    </div>

                    <div class="form-floating mb-2 position-relative">
                        <input type="password" class="form-control pe-5" id="password" name="password"
                            placeholder="Password" required>
                        <label for="password">Password</label>
                        <button type="button" id="togglePasswordBtn"
                            class="btn border-0 position-absolute end-0 top-50 translate-middle-y text-muted px-3"
                            style="z-index: 5;">
                            <!-- Initially hidden password -> eye crossed out -->
                            <i class="bi bi-eye-slash-fill" id="eyeIcon"></i>
                        </button>
                    </div>

                    <div class="text-end mb-4">
                        <a href="/auth/forgot-password"
                            class="text-primary text-decoration-none small fw-semibold">Forgot password?</a>
                    </div>

                    <script>
                        document.addEventListener('DOMContentLoaded', function () {
                            const togglePasswordBtn = document.getElementById('togglePasswordBtn');
                            const passwordInput = document.getElementById('password');
                            const eyeIcon = document.getElementById('eyeIcon');

                            togglePasswordBtn.addEventListener('click', function () {
                                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                                passwordInput.setAttribute('type', type);

                                if (type === 'text') {
                                    // Password visible -> regular open eye
                                    eyeIcon.classList.remove('bi-eye-slash-fill');
                                    eyeIcon.classList.add('bi-eye-fill');
                                } else {
                                    // Password hidden -> crossed-out eye
                                    eyeIcon.classList.remove('bi-eye-fill');
                                    eyeIcon.classList.add('bi-eye-slash-fill');
                                }
                            });
                        });
                    </script>

                    <% if (typeof showCaptcha !=='undefined' && showCaptcha) { %>
                        <div class="mb-4 d-flex justify-content-center">
                            <div class="g-recaptcha" data-sitekey="<%= recaptchaSiteKey %>"></div>
                        </div>
                        <script src="https://www.google.com/recaptcha/api.js" async defer></script>
                        <% } %>

                            <button class="btn gradient-btn w-100 py-3 rounded-pill fw-semibold shadow-sm mb-3"
                                type="submit">Log In to Dashboard</button>

                            <div class="text-center mt-4">
                                <p class="text-muted mb-0">Don't have an account? <a href="/auth/register"
                                        class="text-primary text-decoration-none fw-semibold">Sign up here</a></p>
                            </div>
                </form>
            </div>
            <div class="text-center mt-4">
                <small class="text-muted"><i class="bi bi-lock-fill"></i> Your connection is secure and
                    encrypted.</small>
            </div>
        </div>
    </div>
</div>