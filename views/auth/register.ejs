<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card fintech-card p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="bg-primary-subtle text-primary d-inline-flex p-3 rounded-circle mb-3">
                        <i class="bi bi-person-plus fs-2"></i>
                    </div>
                    <h2 class="fw-bold fs-3">Create an Account</h2>
                    <p class="text-muted">Join the secure digital money revolution</p>
                </div>



                <form action="/auth/register" method="POST">
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label for="name" class="form-label fw-medium text-dark small">Full Name</label>
                            <input type="text" class="form-control form-control-lg bg-light" id="name" name="name"
                                required placeholder="John Doe" maxlength="50"
                                oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '');">
                        </div>
                        <div class="col-md-6">
                            <label for="phone" class="form-label fw-medium text-dark small">Mobile
                                Number</label>
                            <input type="tel" class="form-control form-control-lg bg-light" id="phone" name="phone"
                                required placeholder="+1 234 567 8900" maxlength="15"
                                oninput="this.value = this.value.replace(/[^0-9+\s\-]/g, '');">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label fw-medium text-dark small">Email address</label>
                        <input type="email" class="form-control form-control-lg bg-light" id="email" name="email"
                            required placeholder="name@example.com">
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label fw-medium text-dark small">Password <span
                                class="text-muted fw-normal">(min. 6 characters)</span></label>
                        <div class="input-group">
                            <input type="password" class="form-control form-control-lg bg-light" id="password"
                                name="password" required minlength="6" placeholder="Choose a strong password"
                                style="border-right: none;">
                            <button class="btn bg-light d-flex align-items-center justify-content-center px-3"
                                type="button" id="togglePassword"
                                style="border: 1px solid #dee2e6; border-left: none; border-top-right-radius: var(--bs-border-radius-lg); border-bottom-right-radius: var(--bs-border-radius-lg);">
                                <i class="bi bi-eye-slash text-muted" id="togglePasswordIcon"></i>
                            </button>
                        </div>
                    </div>

                    <script>
                        document.getElementById('togglePassword').addEventListener('click', function (e) {
                            const passwordInput = document.getElementById('password');
                            const icon = document.getElementById('togglePasswordIcon');
                            if (passwordInput.type === 'password') {
                                passwordInput.type = 'text';
                                icon.classList.remove('bi-eye-slash');
                                icon.classList.add('bi-eye');
                            } else {
                                passwordInput.type = 'password';
                                icon.classList.remove('bi-eye');
                                icon.classList.add('bi-eye-slash');
                            }
                        });
                    </script>

                    <div class="alert alert-info py-2 small mb-4">
                        <i class="bi bi-info-circle-fill me-2"></i> You will be asked to verify your email with
                        an OTP on the next step.
                    </div>

                    <button class="btn gradient-btn w-100 py-3 rounded-pill fw-semibold shadow-sm mb-3"
                        type="submit">Agree & Create Account</button>

                    <div class="text-center mt-4">
                        <p class="text-muted mb-0">Already have an account? <a href="/auth/login"
                                class="text-primary text-decoration-none fw-semibold">Log in here</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>