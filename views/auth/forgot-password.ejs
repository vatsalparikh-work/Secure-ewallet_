<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card fintech-card p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="bg-primary-subtle text-primary d-inline-flex p-3 rounded-circle mb-3">
                        <i class="bi bi-shield-lock-fill fs-2"></i>
                    </div>
                    <h2 class="fw-bold fs-3">Forgot Password</h2>
                    <p class="text-muted">Enter your registered email and we'll send you an OTP to reset your
                        password.</p>
                </div>

                <form action="/auth/forgot-password" method="POST">
                    <div class="form-floating mb-4">
                        <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com"
                            required>
                        <label for="email">Email address</label>
                    </div>

                    <button class="btn gradient-btn w-100 py-3 rounded-pill fw-semibold shadow-sm mb-3"
                        type="submit">Send Reset OTP</button>

                    <div class="text-center mt-4">
                        <p class="text-muted mb-0">Remembered your password? <a href="/auth/login"
                                class="text-primary text-decoration-none fw-semibold">Log in here</a></p>
                    </div>
                </form>
            </div>
            <div class="text-center mt-4">
                <small class="text-muted"><i class="bi bi-lock-fill"></i> Your connection is secure and
                    encrypted.</small>
            </div>
        </div>
    </div>
</div>