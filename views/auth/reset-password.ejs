<style>
    .strength-meter {
        height: 5px;
        background-color: #e9ecef;
        border-radius: 3px;
        margin-top: 10px;
        overflow: hidden;
    }

    .strength-meter-fill {
        height: 100%;
        width: 0%;
        transition: width 0.3s ease, background-color 0.3s ease;
    }

    .pwd-weak {
        width: 33%;
        background-color: #dc3545;
    }

    .pwd-medium {
        width: 66%;
        background-color: #ffc107;
    }

    .pwd-strong {
        width: 100%;
        background-color: #198754;
    }
</style>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card fintech-card p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="bg-primary-subtle text-primary d-inline-flex p-3 rounded-circle mb-3">
                        <i class="bi bi-key-fill fs-2"></i>
                    </div>
                    <h2 class="fw-bold fs-3">Set New Password</h2>
                    <p class="text-muted">Create a strong new password for your account.</p>
                </div>

                <form action="/auth/reset-password" method="POST" id="resetPwForm">
                    <div class="form-floating mb-3 position-relative">
                        <input type="password" class="form-control pe-5" id="password" name="newPassword"
                            placeholder="New Password" required minlength="6">
                        <label for="password">New Password</label>
                        <button type="button" id="togglePasswordBtn1"
                            class="btn border-0 position-absolute end-0 top-50 translate-middle-y text-muted px-3"
                            style="z-index: 5;">
                            <i class="bi bi-eye-slash-fill" id="eyeIcon1"></i>
                        </button>
                    </div>

                    <div class="mb-3 px-1">
                        <small id="passwordHelpBlock" class="form-text text-muted">Must be at least 6
                            characters.</small>
                        <div class="strength-meter">
                            <div class="strength-meter-fill" id="strengthFill"></div>
                        </div>
                        <small id="strengthText" class="form-text mt-1 d-block text-end"></small>
                    </div>

                    <div class="form-floating mb-4 position-relative">
                        <input type="password" class="form-control pe-5" id="confirmPassword" name="confirmPassword"
                            placeholder="Confirm New Password" required>
                        <label for="confirmPassword">Confirm New Password</label>
                        <button type="button" id="togglePasswordBtn2"
                            class="btn border-0 position-absolute end-0 top-50 translate-middle-y text-muted px-3"
                            style="z-index: 5;">
                            <i class="bi bi-eye-slash-fill" id="eyeIcon2"></i>
                        </button>
                    </div>

                    <button class="btn gradient-btn w-100 py-3 rounded-pill fw-semibold shadow-sm mb-3" type="submit"
                        id="submitBtn">Update Password</button>

                </form>

                <script>
                    document.addEventListener('DOMContentLoaded', function () {
                        // Show / Hide Handlers
                        const setupToggle = (btnId, inputId, iconId) => {
                            const btn = document.getElementById(btnId);
                            const input = document.getElementById(inputId);
                            const icon = document.getElementById(iconId);

                            btn.addEventListener('click', function () {
                                const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                                input.setAttribute('type', type);

                                if (type === 'text') {
                                    icon.classList.remove('bi-eye-slash-fill');
                                    icon.classList.add('bi-eye-fill');
                                } else {
                                    icon.classList.remove('bi-eye-fill');
                                    icon.classList.add('bi-eye-slash-fill');
                                }
                            });
                        };

                        setupToggle('togglePasswordBtn1', 'password', 'eyeIcon1');
                        setupToggle('togglePasswordBtn2', 'confirmPassword', 'eyeIcon2');

                        // Strength checker
                        const pwdInput = document.getElementById('password');
                        const confPwdInput = document.getElementById('confirmPassword');
                        const strengthFill = document.getElementById('strengthFill');
                        const strengthText = document.getElementById('strengthText');
                        const submitBtn = document.getElementById('submitBtn');
                        const form = document.getElementById('resetPwForm');

                        pwdInput.addEventListener('input', function () {
                            const val = this.value;
                            let strength = 0;

                            strengthFill.className = 'strength-meter-fill';
                            strengthText.textContent = '';

                            if (val.length === 0) return;

                            if (val.length >= 6) strength += 1;
                            if (val.match(/[A-Z]/)) strength += 1;
                            if (val.match(/[0-9]/)) strength += 1;
                            if (val.match(/[^a-zA-Z0-9]/)) strength += 1;
                            if (val.length >= 10) strength += 1;

                            if (strength <= 1) {
                                strengthFill.classList.add('pwd-weak');
                                strengthText.textContent = 'Weak';
                                strengthText.className = 'form-text mt-1 d-block text-end text-danger fw-bold';
                            } else if (strength <= 3) {
                                strengthFill.classList.add('pwd-medium');
                                strengthText.textContent = 'Medium';
                                strengthText.className = 'form-text mt-1 d-block text-end text-warning fw-bold';
                            } else {
                                strengthFill.classList.add('pwd-strong');
                                strengthText.textContent = 'Strong';
                                strengthText.className = 'form-text mt-1 d-block text-end text-success fw-bold';
                            }
                        });

                        form.addEventListener('submit', function (e) {
                            if (pwdInput.value !== confPwdInput.value) {
                                e.preventDefault();
                                alert('Passwords do not match!');
                            }
                        });
                    });
                </script>
            </div>
            <div class="text-center mt-4">
                <small class="text-muted"><i class="bi bi-lock-fill"></i> Your connection is secure and
                    encrypted.</small>
            </div>

            <div class="text-center mt-3">
                <a href="/auth/login" class="text-muted text-decoration-none"><i class="bi bi-arrow-left"></i> Back
                    to Login</a>
            </div>
        </div>
    </div>
</div>