<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | Secure eWallet
    </title>
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png">
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
        }

        [data-theme="dark"] {
            background-color: #121212 !important;
            color: #e0e0e0;
        }

        [data-theme="dark"] body {
            background-color: #121212;
            color: #e0e0e0;
        }

        [data-theme="dark"] .bg-white {
            background-color: #1e1e1e !important;
        }

        [data-theme="dark"] .navbar {
            background-color: #1e1e1e !important;
            border-bottom-color: #333 !important;
        }

        [data-theme="dark"] .fintech-card,
        [data-theme="dark"] .card {
            background-color: #1e1e1e !important;
            color: #e0e0e0;
            border-color: #333 !important;
        }

        [data-theme="dark"] .text-muted {
            color: #adb5bd !important;
        }

        [data-theme="dark"] .bg-light {
            background-color: #2b2b2b !important;
            color: #e0e0e0 !important;
        }

        [data-theme="dark"] .form-control {
            background-color: #2b2b2b !important;
            color: #e0e0e0 !important;
            border-color: #444 !important;
        }

        [data-theme="dark"] .modal-content {
            background-color: #1e1e1e !important;
            color: #e0e0e0;
        }

        [data-theme="dark"] .border-bottom,
        [data-theme="dark"] .border {
            border-color: #333 !important;
        }

        [data-theme="dark"] .nav-link,
        [data-theme="dark"] .navbar-brand {
            color: #e0e0e0 !important;
        }

        [data-theme="dark"] .dropdown-menu {
            background-color: #1e1e1e !important;
            border-color: #333 !important;
        }

        [data-theme="dark"] .dropdown-item {
            color: #e0e0e0 !important;
        }

        [data-theme="dark"] .dropdown-item:hover {
            background-color: #2b2b2b !important;
        }

        [data-theme="dark"] .navbar-brand {
            color: #0d6efd !important;
        }

        .navbar-brand {
            font-weight: 700;
            color: #0d6efd !important;
            letter-spacing: -0.5px;
        }

        .fintech-card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            transition: transform 0.2s ease-in-out;
        }

        .gradient-btn {
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            border: none;
            color: white;
        }

        .gradient-btn:hover {
            background: linear-gradient(135deg, #0a58ca 0%, #084298 100%);
            color: white;
        }

        .form-control:focus {
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100" data-theme="<%= typeof userTheme !== 'undefined' ? userTheme : 'light' %>">

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <i class="bi bi-wallet2 text-primary fs-3 me-2"></i>
                SECURE eWALLET
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav align-items-center">
                    <% if (user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/dashboard"><i class="bi bi-speedometer2 me-1"></i>
                                Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/wallet/transfer"><i class="bi bi-send me-1"></i> Send Money</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/wallet/history"><i class="bi bi-clock-history me-1"></i>
                                History</a>
                        </li>
                        <li class="nav-item dropdown ms-3">
                            <a class="nav-link dropdown-toggle btn btn-light rounded-pill px-3 py-2" href="#"
                                id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i>
                                <%= user.name %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0"
                                aria-labelledby="navbarDropdown">
                                <li><a class="dropdown-item" href="/user/profile"><i class="bi bi-person-gear me-2"></i>
                                        Profile Settings</a></li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li><a class="dropdown-item text-danger" href="/auth/logout"><i
                                            class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                            </ul>
                        </li>
                        <% } else { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/auth/login">Login</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn gradient-btn rounded-pill px-4" href="/auth/register">Create Account</a>
                            </li>
                            <% } %>
                </ul>
            </div>
        </div>
    </nav>
    <main class="flex-grow-1">