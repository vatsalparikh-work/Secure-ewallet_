<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="d-flex align-items-center mb-4">
                <a href="/dashboard" class="btn btn-light rounded-circle me-3"><i class="bi bi-arrow-left"></i></a>
                <h3 class="fw-bold mb-0">Send Money</h3>
            </div>


            <div class="card fintech-card p-4 p-md-5 border-0">
                <form action="/wallet/transfer" method="POST" id="transferForm">

                    <div class="mb-4">
                        <label class="form-label fw-medium text-muted small text-uppercase">Transfer to</label>
                        <div class="input-group input-group-lg shadow-sm rounded-4 overflow-hidden">
                            <span class="input-group-text bg-light border-0"><i
                                    class="bi bi-person text-muted"></i></span>
                            <input type="email" class="form-control border-0 bg-light" name="receiverEmail"
                                placeholder="Recipient's Email Address" required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-medium text-muted small text-uppercase">Amount (₹)</label>
                        <div class="input-group input-group-lg shadow-sm rounded-4 overflow-hidden">
                            <span
                                class="input-group-text bg-white border-primary border-end-0 text-primary fw-bold">₹</span>
                            <input type="number" step="0.01" min="0.01"
                                class="form-control border-primary border-start-0 fw-bold fs-4 text-primary"
                                name="amount" placeholder="0.00" required>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="form-label fw-medium text-muted small text-uppercase">Note
                            (Encrypted)</label>
                        <textarea class="form-control bg-light border-0 shadow-sm rounded-4 p-3" name="note" rows="2"
                            placeholder="What's this for? (Optional)"></textarea>
                    </div>

                    <!-- Hidden PIN input, populated by modal -->
                    <input type="hidden" name="pin" id="hiddenPinInput" required>

                    <button type="button"
                        class="btn gradient-btn w-100 py-3 rounded-pill fw-semibold shadow fw-bold fs-5"
                        data-bs-toggle="modal" data-bs-target="#pinModal">
                        Continue to Transfer
                    </button>

                    <div class="text-center mt-4 text-muted small">
                        <i class="bi bi-shield-lock-fill text-success"></i> End-to-end encrypted transfer
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Transaction PIN Modal -->
<div class="modal fade" id="pinModal" tabindex="-1" aria-labelledby="pinModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body p-4 text-center">
                <h5 class="fw-bold mb-1">Enter Transaction PIN</h5>
                <p class="text-muted small mb-4">Verify it's you to complete transfer</p>

                <input type="password"
                    class="form-control form-control-lg text-center fw-bold letter-spacing-2 mb-4 bg-light shadow-sm"
                    id="modalPinInput" maxlength="6" pattern="\d{6}" placeholder="••••••"
                    style="letter-spacing: 0.5rem; font-size: 1.5rem;" autocomplete="off">

                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-light w-50 rounded-pill fw-medium"
                        data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn gradient-btn w-50 rounded-pill fw-semibold shadow-sm"
                        id="confirmTransferBtn">Confirm</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('confirmTransferBtn').addEventListener('click', function () {
        const pin = document.getElementById('modalPinInput').value;
        if (pin.length === 6) {
            document.getElementById('hiddenPinInput').value = pin;
            document.getElementById('transferForm').submit();
        } else {
            alert("Please enter a valid 6-digit PIN");
        }
    });

    // Clear pin on modal close
    const pinModal = document.getElementById('pinModal')
    pinModal.addEventListener('hidden.bs.modal', event => {
        document.getElementById('modalPinInput').value = '';
    })
</script>