        height: 35px;
        background: linear-gradient(135deg, #fbbf24 0%, #d97706 100%);
        border-radius: 6px;
        position: relative;
        overflow: hidden;
        box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.3);
    }

    .card-chip::after {
        content: '';
        position: absolute;
        width: 100%;
        height: 1px;
        background: rgba(0, 0, 0, 0.2);
        top: 50%;
    }

    .card-number {
